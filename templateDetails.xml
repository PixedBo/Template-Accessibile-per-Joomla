<?xml version='1.0' encoding='utf-8'?>
<extension type="template" client="site" method="upgrade">
  <name>Template Accessibile per Joomla</name>
  <version>@version@</version>
  <creationDate>@date@</creationDate>
  <author>Pixed Web Development</author>
  <authorEmail>info@pixed.it</authorEmail>
  <authorUrl>https://www.pixed.it</authorUrl>
  <copyright>Copyright (C) 2025 Pixed Web Development. All rights reserved.</copyright>
  <license>GNU General Public License version 3 or later; see LICENSE.txt</license>
  <description>Template Joomla 5 conforme alle linee guida Designers Italia e Modello Comuni</description>
  <dependencies>
    <dependency type="core" operator=">=">5.0.0</dependency>
    <dependency type="php" operator=">=">8.2.0</dependency>
  </dependencies>
  <files>
    <filename>README.md</filename>
    <filename>error.php</filename>
    <filename>index.php</filename>
    <filename>offline.php</filename>
    <filename>templateDetails.xml</filename>
    <filename>template_preview.png</filename>
    <filename>template_thumbnail.png</filename>
    <folder>assets</folder>
    <folder>css</folder>
    <folder>fonts</folder>
    <folder>html</folder>
    <folder>images</folder>
    <folder>js</folder>
    <folder>svg</folder>
  </files>
  <languages folder="language">
    <language tag="it-IT">it-IT/tpl_templateaccessibileperjoomla.ini</language>
    <language tag="en-GB">en-GB/tpl_templateaccessibileperjoomla.ini</language>
  </languages>
  <positions>
    <position>selezione-lingua</position>
    <position>menu-principale</position>
    <position>menu-secondario</position>
    <position>percorso</position>
    <position>top</position>
	<position>top-muted</position>
	<position>bottom</position>
	<position>bottom2</position>
	<position>calendario</position>
	<position>evidenza</position>
	<position>colonna-sinistra</position>
	<position>colonna-destra</position>
	<position>footer1</position>
	<position>footer2</position>
  	<position>debug</position>
	<position>cerca-servizi</position>
  </positions>
  <config>
    <fields name="params">
      <fieldset name="basic" label="TPL_ACCESSIBILE_BASIC_LABEL">
        <field name="logotipo" type="media" label="TPL_ACCESSIBILE_LOGO_LABEL" directory="images" preview="true" description="TPL_ACCESSIBILE_LOGO_DESC" />
        <field name="favicon_svg" type="media" label="TPL_ACCESSIBILE_FAVICON_SVG_LABEL" directory="images" description="TPL_ACCESSIBILE_FAVICON_SVG_DESC" />
        <field name="favicon_png" type="media" label="TPL_ACCESSIBILE_FAVICON_PNG_LABEL" directory="images" description="TPL_ACCESSIBILE_FAVICON_PNG_DESC" />
        <field name="nomesito" type="text" default="Il mio Comune" label="TPL_ACCESSIBILE_SITENAME_LABEL" description="TPL_ACCESSIBILE_SITENAME_DESC" size="20" />
        <field name="nomeregione" type="text" default="La mia Regione" label="TPL_ACCESSIBILE_REGION_LABEL" description="TPL_ACCESSIBILE_REGION_DESC" size="20" />
        <field name="linkregione" type="url" default="" label="TPL_ACCESSIBILE_REGION_LINK_LABEL" description="TPL_ACCESSIBILE_REGION_LINK_DESC" size="20" />
        <field name="payoff" type="text" default="Sottotitolo" label="TPL_ACCESSIBILE_PAYOFF_LABEL" description="TPL_ACCESSIBILE_PAYOFF_DESC" size="20" />
        <field name="coloreprimario" type="list" default="#007a52" label="TPL_ACCESSIBILE_PRIMARY_COLOR_LABEL" description="TPL_ACCESSIBILE_PRIMARY_COLOR_DESC">
          <option value="#0066CC">TPL_ACCESSIBILE_COLOR_BLUE</option>
          <option value="#007a52">TPL_ACCESSIBILE_COLOR_GREEN</option>
          <option value="#d1344c">TPL_ACCESSIBILE_COLOR_RED</option>
          <option value="#07768d">TPL_ACCESSIBILE_COLOR_TEAL</option>
          <option value="#7d2670">TPL_ACCESSIBILE_COLOR_PURPLE</option>
        </field>
      </fieldset>

      <fieldset name="opzioni" label="TPL_ACCESSIBILE_HEADER_OPTIONS_LABEL">
        <field name="mostra_login" type="radio" default="0" label="TPL_ACCESSIBILE_SHOW_LOGIN_LABEL" description="TPL_ACCESSIBILE_SHOW_LOGIN_DESC" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="tipo_login" type="list" default="standard" label="TPL_ACCESSIBILE_LOGIN_TYPE_LABEL" description="TPL_ACCESSIBILE_LOGIN_TYPE_DESC" showon="mostra_login:1">
          <option value="standard">TPL_ACCESSIBILE_LOGIN_STANDARD</option>
          <option value="menuitem">TPL_ACCESSIBILE_LOGIN_MENUITEM</option>
        </field>
        <field name="menuitem_login" type="menuitem" default="" label="TPL_ACCESSIBILE_LOGIN_MENUITEM_LABEL" description="TPL_ACCESSIBILE_LOGIN_MENUITEM_DESC" showon="mostra_login:1[AND]tipo_login:menuitem">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        
        <field name="mostra_ricerca" type="radio" default="0" label="TPL_ACCESSIBILE_SHOW_SEARCH_LABEL" description="TPL_ACCESSIBILE_SHOW_SEARCH_DESC" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="tipo_ricerca" type="list" default="smartsearch" label="TPL_ACCESSIBILE_SEARCH_TYPE_LABEL" description="TPL_ACCESSIBILE_SEARCH_TYPE_DESC" showon="mostra_ricerca:1">
          <option value="smartsearch">TPL_ACCESSIBILE_SEARCH_STANDARD</option>
          <option value="menuitem">TPL_ACCESSIBILE_SEARCH_MENUITEM</option>
        </field>
        <field name="menuitem_ricerca" type="menuitem" default="" label="TPL_ACCESSIBILE_SEARCH_MENUITEM_LABEL" description="TPL_ACCESSIBILE_SEARCH_MENUITEM_DESC" showon="mostra_ricerca:1[AND]tipo_ricerca:menuitem">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
      </fieldset>

      <fieldset name="footer" label="TPL_ACCESSIBILE_FOOTER_OPTIONS_LABEL">
        <field name="mostra_logo_ue" type="radio" default="1" label="TPL_ACCESSIBILE_SHOW_EU_LOGO_LABEL" description="TPL_ACCESSIBILE_SHOW_EU_LOGO_DESC" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
      </fieldset>

      <fieldset name="social" label="TPL_ACCESSIBILE_SOCIAL_LABEL">
        <field name="socialx" type="url" label="TPL_ACCESSIBILE_SOCIAL_X_LABEL" description="TPL_ACCESSIBILE_SOCIAL_X_DESC" size="20" />
        <field name="facebook" type="url" label="TPL_ACCESSIBILE_SOCIAL_FB_LABEL" description="TPL_ACCESSIBILE_SOCIAL_FB_DESC" size="20" />
        <field name="youtube" type="url" label="TPL_ACCESSIBILE_SOCIAL_YT_LABEL" description="TPL_ACCESSIBILE_SOCIAL_YT_DESC" size="20" />
        <field name="telegram" type="url" label="TPL_ACCESSIBILE_SOCIAL_TG_LABEL" description="TPL_ACCESSIBILE_SOCIAL_TG_DESC" size="20" />
        <field name="whatsapp" type="text" label="TPL_ACCESSIBILE_SOCIAL_WA_LABEL" description="TPL_ACCESSIBILE_SOCIAL_WA_DESC" size="20" />
		<field name="linkedin" type="url" label="TPL_ACCESSIBILE_SOCIAL_LI_LABEL" description="TPL_ACCESSIBILE_SOCIAL_LI_DESC" size="20" />
      </fieldset>

      <fieldset name="valutazione" label="TPL_ACCESSIBILE_FIELDSET_VALUTAZIONE_COMUNI_LABEL" description="TPL_ACCESSIBILE_FIELDSET_VALUTAZIONE_DESC">
        <field name="mostra_feedback" type="radio" default="0" label="TPL_ACCESSIBILE_SHOW_FEEDBACK_LABEL" description="TPL_ACCESSIBILE_SHOW_FEEDBACK_DESC" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="de_management" type="menuitem" label="TPL_ACCESSIBILE_DE_MANAGEMENT_LABEL" description="TPL_ACCESSIBILE_DE_MANAGEMENT_DESC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="de_news" type="menuitem" label="TPL_ACCESSIBILE_DE_NEWS_LABEL" description="TPL_ACCESSIBILE_DE_NEWS_DESC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="de_all_services" type="menuitem" label="TPL_ACCESSIBILE_DE_ALL_SERVICES_LABEL" description="TPL_ACCESSIBILE_DE_ALL_SERVICES_DESC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="de_live" type="menuitem" label="TPL_ACCESSIBILE_DE_LIVE_LABEL" description="TPL_ACCESSIBILE_DE_LIVE_DESC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="de_faq" type="menuitem" label="TPL_ACCESSIBILE_DE_FAQ_LABEL" description="TPL_ACCESSIBILE_DE_FAQ_DESC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="de_report_inefficiency" type="menuitem" label="TPL_ACCESSIBILE_DE_REPORT_LABEL" description="TPL_ACCESSIBILE_DE_REPORT_DESC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="de_accessibility_link" type="menuitem" label="TPL_ACCESSIBILE_DE_ACCESSIBILITY_LABEL" description="TPL_ACCESSIBILE_DE_ACCESSIBILITY_DESC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="de_privacy_policy_link" type="menuitem" label="TPL_ACCESSIBILE_DE_PRIVACY_LABEL" description="TPL_ACCESSIBILE_DE_PRIVACY_DESC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="de_all_topics" type="menuitem" label="TPL_ACCESSIBILE_DE_ALL_TOPICS_LABEL" description="TPL_ACCESSIBILE_DE_ALL_TOPICS_DESC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>

        <field type="note" label="TPL_ACCESSIBILE_SCHEDA_SERVIZIO_NOTE_LABEL" description="TPL_ACCESSIBILE_SCHEDA_SERVIZIO_NOTE_DESC" class="alert alert-info" />

        <field name="cf_stato" type="sql" label="TPL_ACCESSIBILE_CF_STATO_LABEL" description="TPL_ACCESSIBILE_CF_STATO_DESC" key_field="id" value_field="title" query="SELECT id, title FROM #__fields WHERE state = 1 AND context = 'com_content.article' ORDER BY title ASC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="cf_a_chi_rivolto" type="sql" label="TPL_ACCESSIBILE_CF_A_CHI_RIVOLTO_LABEL" description="TPL_ACCESSIBILE_CF_A_CHI_RIVOLTO_DESC" key_field="id" value_field="title" query="SELECT id, title FROM #__fields WHERE state = 1 AND context = 'com_content.article' ORDER BY title ASC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="cf_come_fare" type="sql" label="TPL_ACCESSIBILE_CF_COME_FARE_LABEL" description="TPL_ACCESSIBILE_CF_COME_FARE_DESC" key_field="id" value_field="title" query="SELECT id, title FROM #__fields WHERE state = 1 AND context = 'com_content.article' ORDER BY title ASC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="cf_cosa_serve" type="sql" label="TPL_ACCESSIBILE_CF_COSA_SERVE_LABEL" description="TPL_ACCESSIBILE_CF_COSA_SERVE_DESC" key_field="id" value_field="title" query="SELECT id, title FROM #__fields WHERE state = 1 AND context = 'com_content.article' ORDER BY title ASC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="cf_cosa_si_ottiene" type="sql" label="TPL_ACCESSIBILE_CF_COSA_SI_OTTIENE_LABEL" description="TPL_ACCESSIBILE_CF_COSA_SI_OTTIENE_DESC" key_field="id" value_field="title" query="SELECT id, title FROM #__fields WHERE state = 1 AND context = 'com_content.article' ORDER BY title ASC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="cf_tempi_scadenze" type="sql" label="TPL_ACCESSIBILE_CF_TEMPI_SCADENZE_LABEL" description="TPL_ACCESSIBILE_CF_TEMPI_SCADENZE_DESC" key_field="id" value_field="title" query="SELECT id, title FROM #__fields WHERE state = 1 AND context = 'com_content.article' ORDER BY title ASC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field type="note"
          label="TPL_ACCESSIBILE_TEMPI_LISTA_NOTE_LABEL"
          description="TPL_ACCESSIBILE_TEMPI_LISTA_NOTE_DESC"
          class="alert alert-info" />
        <field name="cf_tempi_scadenze_lista" type="sql" label="TPL_ACCESSIBILE_CF_TEMPI_SCADENZE_LISTA_LABEL" description="TPL_ACCESSIBILE_CF_TEMPI_SCADENZE_LISTA_DESC" key_field="id" value_field="title" query="SELECT id, title FROM #__fields WHERE state = 1 AND context = 'com_content.article' AND type = 'subform' ORDER BY title ASC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="cf_tempi_lista_key_titolo" type="sql" label="TPL_ACCESSIBILE_CF_TEMPI_LISTA_KEY_TITOLO_LABEL" description="TPL_ACCESSIBILE_CF_TEMPI_LISTA_KEY_TITOLO_DESC" key_field="id" value_field="label" query="SELECT id, CONCAT(title, ' [', name, ']') AS label FROM #__fields WHERE state = 1 AND context = 'com_content.article' AND only_use_in_subform = 1 ORDER BY title ASC" default="titolo">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="cf_tempi_lista_key_data" type="sql" label="TPL_ACCESSIBILE_CF_TEMPI_LISTA_KEY_DATA_LABEL" description="TPL_ACCESSIBILE_CF_TEMPI_LISTA_KEY_DATA_DESC" key_field="id" value_field="label" query="SELECT id, CONCAT(title, ' [', name, ']') AS label FROM #__fields WHERE state = 1 AND context = 'com_content.article' AND only_use_in_subform = 1 ORDER BY title ASC" default="data">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="cf_tempi_lista_key_numero" type="sql" label="TPL_ACCESSIBILE_CF_TEMPI_LISTA_KEY_NUMERO_LABEL" description="TPL_ACCESSIBILE_CF_TEMPI_LISTA_KEY_NUMERO_DESC" key_field="id" value_field="label" query="SELECT id, CONCAT(title, ' [', name, ']') AS label FROM #__fields WHERE state = 1 AND context = 'com_content.article' AND only_use_in_subform = 1 ORDER BY title ASC" default="numero">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="cf_tempi_lista_key_unita" type="sql" label="TPL_ACCESSIBILE_CF_TEMPI_LISTA_KEY_UNITA_LABEL" description="TPL_ACCESSIBILE_CF_TEMPI_LISTA_KEY_UNITA_DESC" key_field="id" value_field="label" query="SELECT id, CONCAT(title, ' [', name, ']') AS label FROM #__fields WHERE state = 1 AND context = 'com_content.article' AND only_use_in_subform = 1 ORDER BY title ASC" default="unita">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="cf_tempi_lista_key_descrizione" type="sql" label="TPL_ACCESSIBILE_CF_TEMPI_LISTA_KEY_DESCRIZIONE_LABEL" description="TPL_ACCESSIBILE_CF_TEMPI_LISTA_KEY_DESCRIZIONE_DESC" key_field="id" value_field="label" query="SELECT id, CONCAT(title, ' [', name, ']') AS label FROM #__fields WHERE state = 1 AND context = 'com_content.article' AND only_use_in_subform = 1 ORDER BY title ASC" default="descrizione">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="cf_quanto_costa" type="sql" label="TPL_ACCESSIBILE_CF_QUANTO_COSTA_LABEL" description="TPL_ACCESSIBILE_CF_QUANTO_COSTA_DESC" key_field="id" value_field="title" query="SELECT id, title FROM #__fields WHERE state = 1 AND context = 'com_content.article' ORDER BY title ASC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="cf_accedi_online" type="sql" label="TPL_ACCESSIBILE_CF_ACCEDI_ONLINE_LABEL" description="TPL_ACCESSIBILE_CF_ACCEDI_ONLINE_DESC" key_field="id" value_field="title" query="SELECT id, title FROM #__fields WHERE state = 1 AND context = 'com_content.article' ORDER BY title ASC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="cf_accedi_online_testo" type="sql" label="TPL_ACCESSIBILE_CF_ACCEDI_ONLINE_TESTO_LABEL" description="TPL_ACCESSIBILE_CF_ACCEDI_ONLINE_TESTO_DESC" key_field="id" value_field="title" query="SELECT id, title FROM #__fields WHERE state = 1 AND context = 'com_content.article' ORDER BY title ASC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="cf_accedi_appuntamento" type="sql" label="TPL_ACCESSIBILE_CF_ACCEDI_APPUNTAMENTO_LABEL" description="TPL_ACCESSIBILE_CF_ACCEDI_APPUNTAMENTO_DESC" key_field="id" value_field="title" query="SELECT id, title FROM #__fields WHERE state = 1 AND context = 'com_content.article' ORDER BY title ASC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="cf_condizioni" type="sql" label="TPL_ACCESSIBILE_CF_CONDIZIONI_LABEL" description="TPL_ACCESSIBILE_CF_CONDIZIONI_DESC" key_field="id" value_field="title" query="SELECT id, title FROM #__fields WHERE state = 1 AND context = 'com_content.article' ORDER BY title ASC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="cf_condizioni_file" type="sql" label="TPL_ACCESSIBILE_CF_CONDIZIONI_FILE_LABEL" description="TPL_ACCESSIBILE_CF_CONDIZIONI_FILE_DESC" key_field="id" value_field="title" query="SELECT id, title FROM #__fields WHERE state = 1 AND context = 'com_content.article' ORDER BY title ASC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="menuitem_contatti_area" type="menuitem" label="TPL_ACCESSIBILE_MENUITEM_CONTATTI_AREA_LABEL" description="TPL_ACCESSIBILE_MENUITEM_CONTATTI_AREA_DESC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
        <field name="menuitem_contatti" type="menuitem" label="TPL_ACCESSIBILE_MENUITEM_CONTATTI_LABEL" description="TPL_ACCESSIBILE_MENUITEM_CONTATTI_DESC" default="">
          <option value="">TPL_ACCESSIBILE_NONE_SELECTED</option>
        </field>
      </fieldset>
    </fields>
  </config>
  <updateservers>
		<server type="extension" name="Template Accessibile per Joomla">https://raw.githubusercontent.com/PixedBo/Template-Accessibile-per-Joomla/main/updateserver.xml</server>
  </updateservers>
</extension>
