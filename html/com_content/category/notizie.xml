            <field
                name="show_featured_news"
                type="radio"
                default="1"
                label="Mostra sezione «In evidenza»"
                description="Se attivo, mostra i primi N articoli in evidenza nella parte alta della pagina (solo a pagina 1)."
                class="btn-group btn-group-yesno">
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field
                name="featured_news_count"
                type="number"
                default="3"
                min="1"
                max="12"
                label="Numero articoli in evidenza"
                description="Quanti articoli mostrare nella sezione «In evidenza». Visibile solo se la sezione è attiva."
                showon="show_featured_news:1" />
        </fieldset>

