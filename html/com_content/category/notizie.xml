<?xml version="1.0" encoding="utf-8"?>
<metadata>
    <layout title="Notizie (Modello PA)" option="Notizie (Modello PA)">
        <help key="Articles:_Category_Blog" />
        <message>
            <![CDATA[Layout dedicato alla categoria Notizie del Comune (Designers Italia). Applica gli attributi data-element richiesti dall'App Valutazione Modelli.]]>
        </message>
    </layout>

    <fields name="request">
        <fieldset name="request">
            <field
                name="id"
                type="category"
                extension="com_content"
                label="JCATEGORY"
                required="true"
            />
        </fieldset>
    </fields>

